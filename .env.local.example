# ─────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in the values.
# See SETUP.md for step-by-step instructions.
# ─────────────────────────────────────────────────────────────

# The Web app URL from deploying apps-script/Code.gs (ends with /exec)
APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXX/exec

# Must EXACTLY match the SECRET variable inside the Apps Script
APPS_SCRIPT_SECRET=your-long-random-secret

# ID of the (link-viewable) Google Sheet holding the video list
# (columns: title, youtube_id, youtube_url, upload_time)
VIDEOS_SHEET_ID=your-videos-sheet-id

# Password the admin uses to sign in at /admin/login
ADMIN_PASSWORD=change-me-to-something-strong

# Any long random string — used to sign the admin session cookie.
SESSION_SECRET=change-me-to-a-long-random-string
